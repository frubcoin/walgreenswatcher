# Flask / Session security
FLASK_SECRET_KEY=change-me
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
# Optional when frontend and backend live on sibling subdomains like app.example.com + api.example.com
# SESSION_COOKIE_DOMAIN=.example.com

# Google auth
# Create a Google OAuth "Web application" client and paste the client ID here.
GOOGLE_CLIENT_ID=

# Admin panel
# Required to unlock /admin and the admin API.
ADMIN_PANEL_PASSWORD=

# CORS
# Comma-separated list of allowed frontend origins.
# Example: https://app.example.com,http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Discord webhook URL(s) used as defaults when a user has not configured their own destinations.
# Multiple webhooks can be separated with commas.
DISCORD_WEBHOOK_URL=
