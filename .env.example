# Discord webhook URL(s) for notifications
# Get this from your Discord server settings:
# 1. Go to Server Settings > Integrations
# 2. Create a Webhook  
# 3. Copy the webhook URL
# Multiple webhooks can be separated with commas
DISCORD_WEBHOOK_URL=

# Optional: Customize these if needed
# WALGREENS_ZIP_CODE=85208
# SEARCH_RADIUS_MILES=90
# CHECK_INTERVAL_HOURS=1
